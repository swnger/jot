{
  "name": "@mariozechner/jot",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "jot": "cli/jot.mjs"
  },
  "files": [
    "build",
    "dist",
    "public",
    "cli"
  ],
  "description": "Minimal self-hosted markdown editor with inline comment threads",
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "dev:kit": "vite dev",
    "build": "svelte-kit sync && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "articulated": "^1.3.1",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.4.1",
    "mermaid": "^11.14.0",
    "sanitize-html": "^2.17.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/ws": "^8.18.1",
    "svelte": "^5.55.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
